<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <title>United Group Inc. | Professional Storm Damage Inspections</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #ffffff;
            color: #333;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        :root {
            --navy: #001f3f;
            --white: #ffffff;
            --red: #d32f2f;
            --gold: #d4af37;
            --light-gray: #f5f5f5;
        }

        h1, h2, h3 { font-family: 'Montserrat', sans-serif; font-weight: 700; }
        h1 { font-size: clamp(2rem, 6vw, 3.5rem); line-height: 1.2; }
        h2 { font-size: clamp(1.5rem, 4vw, 2.5rem); line-height: 1.3; }
        h3 { font-size: 1.25rem; }
        p { font-size: 1rem; line-height: 1.7; color: #555; }

        .btn {
            display: inline-block;
            padding: 14px 32px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            text-align: center;
        }

        .btn-primary {
            background: var(--red);
            color: white;
            box-shadow: 0 8px 24px rgba(211, 47, 47, 0.2);
        }

        .btn-primary:hover,
        .btn-primary:active {
            background: #b71c1c;
            transform: translateY(-4px);
            box-shadow: 0 16px 40px rgba(211, 47, 47, 0.35);
        }

        .btn-secondary {
            background: var(--navy);
            color: white;
            box-shadow: 0 8px 24px rgba(0, 31, 63, 0.2);
        }

        .btn-secondary:hover,
        .btn-secondary:active {
            background: #000a1a;
            transform: translateY(-4px);
            box-shadow: 0 16px 40px rgba(0, 31, 63, 0.35);
        }

        header {
            background: var(--navy);
            color: white;
            padding: 1.2rem 0;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: white;
        }

        .logo-accent { color: var(--gold); }

        .header-phone {
            font-weight: 600;
        }

        .header-phone a {
            color: var(--gold);
            text-decoration: none;
        }

        /* HERO */
        .hero {
            background: linear-gradient(135deg, var(--navy) 0%, #003d5c 100%);
            color: white;
            padding: 100px 20px;
            text-align: center;
            position: relative;
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        .hero-content {
            max-width: 800px;
            position: relative;
            z-index: 2;
        }

        .hero h1 { color: white; margin-bottom: 1rem; }
        .hero-accent { color: var(--gold); font-size: 1.3rem; font-weight: 600; display: block; margin-bottom: 1.5rem; }
        .hero-subtitle { font-size: 1.1rem; line-height: 1.8; color: #e0e0e0; margin-bottom: 2.5rem; }
        .hero-cta { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

        section { padding: 80px 20px; position: relative; }
        .section-container { max-width: 1200px; margin: 0 auto; }
        .section-title { text-align: center; margin-bottom: 3.5rem; }
        .section-title h2 { color: var(--navy); margin-bottom: 0.8rem; }
        .section-title p { font-size: 1.05rem; color: #666; }

        .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 2rem; }
        .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin-top: 2rem; }

        .card {
            background: white;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 2rem;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .card:hover {
            border-color: var(--gold);
            box-shadow: 0 20px 60px rgba(212, 175, 55, 0.15);
            transform: translateY(-8px);
        }

        .card-icon { font-size: 3rem; margin-bottom: 1rem; }
        .card h3 { color: var(--navy); margin-bottom: 1rem; }
        .card p { color: #666; font-size: 0.95rem; }

        .process-step {
            text-align: center;
            padding: 2rem;
            transition: all 0.4s ease;
        }

        .step-number {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--red), #ff5252);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0 auto 1.5rem;
            font-family: 'Montserrat', sans-serif;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 8px 24px rgba(211, 47, 47, 0.2);
        }

        .process-step:hover .step-number {
            transform: scale(1.15);
            background: linear-gradient(135deg, var(--gold), #ffb300);
            color: var(--navy);
            box-shadow: 0 12px 40px rgba(212, 175, 55, 0.3);
        }

        .process-step h3 { color: var(--navy); margin-bottom: 0.5rem; }
        .process-step p { color: #666; font-size: 0.95rem; }

        .stat-item { text-align: center; padding: 2rem; }
        .stat-number {
            font-family: 'Montserrat', sans-serif;
            font-size: 2.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--gold), #ffb300);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }
        .stat-label { font-size: 0.95rem; color: #666; font-weight: 600; }

        .cert-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 2rem;
            align-items: center;
            justify-items: center;
            margin-top: 2rem;
        }

        .cert-item {
            text-align: center;
            transition: all 0.4s ease;
        }

        .cert-badge {
            width: 120px;
            height: 120px;
            margin: 0 auto 1rem;
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .cert-item:hover .cert-badge {
            transform: scale(1.1);
        }

        .cert-badge img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .cert-item p { color: var(--navy); font-weight: 600; font-size: 1rem; margin-bottom: 0.3rem; }
        .cert-item small { color: #666; font-size: 0.85rem; }

        .cta-section {
            background: linear-gradient(135deg, var(--navy) 0%, #003d5c 100%);
            color: white;
            text-align: center;
            padding: 80px 20px;
            position: relative;
        }

        .cta-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 80% 20%, rgba(212, 175, 55, 0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        .cta-section h2 { color: white; margin-bottom: 1.5rem; position: relative; z-index: 1; }
        .cta-subtitle { font-size: 1.05rem; color: #e0e0e0; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto; position: relative; z-index: 1; }
        .cta-buttons { position: relative; z-index: 1; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

        footer {
            background: var(--light-gray);
            border-top: 4px solid var(--red);
            padding: 3rem 20px;
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .footer-section h4 {
            font-family: 'Montserrat', sans-serif;
            color: var(--navy);
            margin-bottom: 1rem;
            font-weight: 700;
        }

        .footer-section p, .footer-section a {
            color: #666;
            font-size: 0.95rem;
            line-height: 1.8;
        }

        .footer-section a {
            text-decoration: none;
            transition: color 0.25s ease;
        }

        .footer-section a:hover { color: var(--red); }

        .footer-bottom {
            text-align: center;
            border-top: 1px solid #ddd;
            padding-top: 2rem;
            color: #999;
            max-width: 1200px;
            margin: 0 auto;
        }

        @media (max-width: 768px) {
            section { padding: 60px 20px; }
            .hero { padding: 60px 20px; min-height: 50vh; }
            .hero-cta { flex-direction: column; }
            .btn { width: 100%; }
            .grid-2, .grid-4 { grid-template-columns: 1fr; }
            .stat-number { font-size: 2.2rem; }
            .cert-badge { width: 100px; height: 100px; }
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header>
        <div class="header-content">
            <div class="logo">United <span class="logo-accent">Group</span></div>
            <div class="header-phone">📞 <a href="tel:+18562548367">(856) 254-8367</a></div>
        </div>
    </header>

    <!-- HERO -->
    <section class="hero">
        <div class="hero-content">
            <h1>Storm Damage Inspections</h1>
            <span class="hero-accent">Professional Assessment. Maximize Your Coverage.</span>
            <p class="hero-subtitle">We help homeowners document storm damage and navigate insurance claims with expert inspections and guidance.</p>
            <div class="hero-cta">
                <button class="btn btn-primary" onclick="document.getElementById('process').scrollIntoView({behavior: 'smooth'})">Request Free Inspection</button>
                <a href="tel:+18562548367" class="btn btn-secondary">Call Us Now</a>
            </div>
        </div>
    </section>

    <!-- WHY US -->
    <section style="background: var(--light-gray);">
        <div class="section-container">
            <div class="section-title">
                <h2>Why Choose United Group</h2>
                <p>Professional inspections that protect your interests</p>
            </div>
            <div class="grid-2">
                <div class="card">
                    <div class="card-icon">🔍</div>
                    <h3>Expert Assessment</h3>
                    <p>Certified inspectors document every detail of storm damage with professional precision.</p>
                </div>
                <div class="card">
                    <div class="card-icon">📋</div>
                    <h3>Insurance Guidance</h3>
                    <p>We ensure your claim reflects the full extent of damage and maximize your coverage.</p>
                </div>
                <div class="card">
                    <div class="card-icon">⚡</div>
                    <h3>Fast Response</h3>
                    <p>Emergency inspections available within 48 hours of storm events.</p>
                </div>
                <div class="card">
                    <div class="card-icon">✓</div>
                    <h3>No Hidden Costs</h3>
                    <p>Free assessment, transparent pricing, no surprises. Your interests come first.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- STATS -->
    <section class="stats-section">
        <div class="section-container">
            <div class="grid-4">
                <div class="stat-item">
                    <div class="stat-number">100+</div>
                    <div class="stat-label">Inspections Completed</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">98%</div>
                    <div class="stat-label">Customer Satisfaction</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">48hr</div>
                    <div class="stat-label">Emergency Response</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">$M+</div>
                    <div class="stat-label">Claims Documented</div>
                </div>
            </div>
        </div>
    </section>

    <!-- PROCESS -->
    <section id="process" style="background: var(--light-gray);">
        <div class="section-container">
            <div class="section-title">
                <h2>Our Process</h2>
                <p>From inspection to claim support in four simple steps</p>
            </div>
            <div class="grid-4">
                <div class="process-step">
                    <div class="step-number">1</div>
                    <h3>Schedule</h3>
                    <p>Contact us and schedule your free assessment at a convenient time.</p>
                </div>
                <div class="process-step">
                    <div class="step-number">2</div>
                    <h3>Inspect</h3>
                    <p>Our certified inspectors document all damage with photos and detailed reports.</p>
                </div>
                <div class="process-step">
                    <div class="step-number">3</div>
                    <h3>Support</h3>
                    <p>We provide comprehensive documentation to support your claim.</p>
                </div>
                <div class="process-step">
                    <div class="step-number">4</div>
                    <h3>Maximize</h3>
                    <p>Pursue the coverage you deserve with our expert assessment.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CERTIFICATIONS -->
    <section>
        <div class="section-container">
            <div class="section-title">
                <h2>Certified & Trusted</h2>
                <p>Professional credentials you can rely on</p>
            </div>
            <div class="cert-grid">
                <div class="cert-item">
                    <div class="cert-badge">
                        <img src="/images/gaf-master-elite.png" alt="GAF Master Elite" />
                    </div>
                    <p>GAF Master Elite</p>
                    <small>Certified</small>
                </div>
                <div class="cert-item">
                    <div style="font-size: 3.5rem; margin-bottom: 0.5rem;">🛡️</div>
                    <p>Fully Insured</p>
                    <small>Coverage</small>
                </div>
                <div class="cert-item">
                    <div style="font-size: 3.5rem; margin-bottom: 0.5rem;">✓</div>
                    <p>Bonded</p>
                    <small>Protection</small>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
        <div class="section-container">
            <h2>Ready to Protect Your Home?</h2>
            <p class="cta-subtitle">A professional storm damage inspection is the first step to protecting your home and maximizing your insurance coverage.</p>
            <div class="cta-buttons">
                <button class="btn btn-primary">Request Free Inspection</button>
                <a href="tel:+18562548367" class="btn btn-secondary">Call (856) 254-8367</a>
                <a href="mailto:Berkakin444@icloud.com" class="btn" style="background: var(--gold); color: var(--navy);">Email Us</a>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <div class="footer-content">
            <div class="footer-section">
                <h4>United Group Inc.</h4>
                <p>Professional storm damage inspections helping homeowners protect their investments.</p>
                <p style="margin-top: 1rem; font-weight: 600; color: var(--navy);">✓ GAF Master Elite Certified</p>
            </div>
            <div class="footer-section">
                <h4>Services</h4>
                <p><a href="#">Storm Damage Inspections</a></p>
                <p><a href="#">Insurance Claim Support</a></p>
                <p><a href="#">Free Assessment</a></p>
            </div>
            <div class="footer-section">
                <h4>Contact</h4>
                <p>📞 <a href="tel:+18562548367">(856) 254-8367</a></p>
                <p>✉️ <a href="mailto:Berkakin444@icloud.com">Email Us</a></p>
                <p>📍 Westville, NJ</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 United Group Inc. All rights reserved.</p>
        </div>
    </footer>

    <script>
        gsap.registerPlugin(ScrollTrigger);

        // Hero Animation
        gsap.timeline()
            .from("h1", { duration: 0.8, y: 30, opacity: 0, ease: "power3.out" })
            .from(".hero-accent", { duration: 0.8, y: 30, opacity: 0, ease: "power3.out" }, "-=0.6")
            .from(".hero-subtitle", { duration: 0.8, y: 30, opacity: 0, ease: "power3.out" }, "-=0.6")
            .from(".hero-cta", { duration: 0.8, y: 30, opacity: 0, ease: "power3.out" }, "-=0.6");

        // Card Scroll Animations
        gsap.utils.toArray(".card").forEach((card) => {
            gsap.from(card, {
                scrollTrigger: {
                    trigger: card,
                    start: "top 85%",
                    end: "top 50%",
                    scrub: false
                },
                y: 40,
                opacity: 0,
                duration: 0.7,
                ease: "power2.out"
            });
        });

        // Stats Animation
        gsap.from(".stat-item", {
            scrollTrigger: {
                trigger: ".stats-section",
                start: "top 80%",
                end: "top 20%",
                scrub: 1
            },
            y: 50,
            opacity: 0,
            stagger: 0.1,
            duration: 0.8,
            ease: "power2.out"
        });

        // Process Steps Animation
        gsap.from(".process-step", {
            scrollTrigger: {
                trigger: "#process",
                start: "top 80%",
                end: "top 20%",
                scrub: 1
            },
            y: 60,
            opacity: 0,
            stagger: 0.2,
            duration: 1,
            ease: "power2.out"
        });

        // Cert Items Animation
        gsap.from(".cert-item", {
            scrollTrigger: {
                trigger: ".cert-grid",
                start: "top 80%",
                end: "top 30%",
                scrub: 1
            },
            scale: 0.8,
            opacity: 0,
            stagger: 0.15,
            duration: 0.8,
            ease: "back.out"
        });

        // CTA Animation
        gsap.from(".cta-section h2, .cta-subtitle", {
            scrollTrigger: {
                trigger: ".cta-section",
                start: "top 80%",
                end: "top 30%",
                scrub: 1
            },
            y: 50,
            opacity: 0,
            stagger: 0.2,
            duration: 0.8,
            ease: "power2.out"
        });
    </script>

</body>
</html>
